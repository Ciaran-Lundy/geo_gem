{
    "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
    "vcs": {
        "enabled": false,
        "clientKind": "git"
    },
    "files": {
        "ignoreUnknown": false,
        "ignore": [".git/", ".build/", "node_modules/"]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "tab",
        "lineWidth": 120
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double",
            "semicolons": "always",
            "trailingCommas": "all"
        }
    },
    "organizeImports": {
        "enabled": true
    }
}
